const DET =
m11 * m22 * m33 +
m12 * m23 * m31 +
m13 * m21 * m32 -
m31 * m22 * m13 -
m32 * m23 * m11 -
m33 * m21 * m12;

document.getElementById("d11").value = m11;
document.getElementById("d12").value = m12;
document.getElementById("d13").value = m13;
document.getElementById("d21").value = m21;
document.getElementById("d22").value = m22;
document.getElementById("d23").value = m23;
document.getElementById("d31").value = m31;
document.getElementById("d32").value = m32;
document.getElementById("d33").value = m33;

// Bayangan
document.getElementById("db11").value = m11;
document.getElementById("db12").value = m12;
document.getElementById("db21").value = m21;
document.getElementById("db22").value = m22;
document.getElementById("db31").value = m31;
document.getElementById("db32").value = m32;

resultDet.value = DET;

// Kofaktor
const minor11 = (m22 * m33 - m23 * m32) * 1;
const minor12 = (m21 * m33 - m23 * m31) * -1;
const minor13 = (m21 * m32 - m22 * m31) * 1;

const minor21 = (m12 * m33 - m13 * m32) * -1;
const minor22 = (m11 * m33 - m13 * m31) * 1;
const minor23 = (m11 * m32 - m12 * m31) * -1;

const minor31 = (m12 * m23 - m13 * m22) * 1;
const minor32 = (m11 * m23 - m13 * m21) * -1;
const minor33 = (m11 * m22 - m12 * m21) * 1;

document.getElementById("k11").value = minor11;
document.getElementById("k12").value = minor12;
document.getElementById("k13").value = minor13;
document.getElementById("k21").value = minor21;
document.getElementById("k22").value = minor22;
document.getElementById("k23").value = minor23;
document.getElementById("k31").value = minor31;
document.getElementById("k32").value = minor32;
document.getElementById("k33").value = minor33;

// Adjoin
document.getElementById("a11").value = minor11;
document.getElementById("a12").value = minor21;
document.getElementById("a13").value = minor31;
document.getElementById("a21").value = minor12;
document.getElementById("a22").value = minor22;
document.getElementById("a23").value = minor32;
document.getElementById("a31").value = minor13;
document.getElementById("a32").value = minor23;
document.getElementById("a33").value = minor33;